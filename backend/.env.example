# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=crm_pass
DB_POOL_SIZE=10

# JWT — ОБЯЗАТЕЛЬНО поменяй в проде!
JWT_SECRET=your_super_secret_key_at_least_32_chars_long
JWT_EXPIRY_HOURS=24

# Server
PORT=8000
THREADS=4
DEBUG=true

# CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (опционально)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
